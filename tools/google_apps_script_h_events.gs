function ensureHeaders_(sheet, expectedHeaders) {
  if (sheet.getLastRow() < 1 || clean_(sheet.getRange(1,1).getValue()) === "") sheet.getRange(1,1,1,expectedHeaders.length).setValues([expectedHeaders]);
  const values = sheet.getRange(1,1,1,Math.max(sheet.getLastColumn(),expectedHeaders.length)).getValues()[0].map(clean_);
  expectedHeaders.forEach(h => { if (values.indexOf(h) < 0) sheet.getRange(1, sheet.getLastColumn() + 1).setValue(h); });
}
function upsertRows_(sheet, expectedHeaders, desiredRows, keyFn) {
  const headers = headerMap_(sheet), lastRow = sheet.getLastRow();
  const existing = new Map();
  if (lastRow >= 2) sheet.getRange(2,1,lastRow-1,sheet.getLastColumn()).getValues().forEach((r,i) => { const key = keyFn(rowByHeaders_(r, expectedHeaders, headers)); if (key) existing.set(key, i + 2); });
  const append = []; let inserted = 0, filled = 0;
  desiredRows.forEach(row => { const key = keyFn(row); if (!key) return; if (!existing.has(key)) { append.push(row); inserted++; return; } const rowNo = existing.get(key); expectedHeaders.forEach((h,i) => { const col = headers[h]; if (!col || row[i] === "" || row[i] == null) return; if (clean_(sheet.getRange(rowNo,col).getValue()) === "") { sheet.getRange(rowNo,col).setValue(row[i]); filled++; } }); });
