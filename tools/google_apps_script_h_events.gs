function setupHEventTextTables() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const payload = JSON.parse(H_EVENT_BASE_JSON_PARTS.join(""));
  const defsSheet = ensureSheet_(ss, "h_event_defs");
  const linesSheet = ensureSheet_(ss, "h_event_lines");
  ensureHeaders_(defsSheet, H_EVENT_DEF_HEADERS);
  ensureHeaders_(linesSheet, H_EVENT_LINE_HEADERS);
  const defsResult = upsertRows_(defsSheet, H_EVENT_DEF_HEADERS, payload.defs, row => clean_(row[0]));
  const linesResult = upsertRows_(linesSheet, H_EVENT_LINE_HEADERS, payload.lines, row => `${clean_(row[0])}::${pad3_(row[1])}`);
  formatSheet_(defsSheet, H_EVENT_DEF_HEADERS);
  formatSheet_(linesSheet, H_EVENT_LINE_HEADERS);
  const l10nResult = syncHEventLocalizationTexts();
  SpreadsheetApp.getActive().toast(`H event tables updated: defs +${defsResult.inserted}, lines +${linesResult.inserted}, l10n +${l10nResult.inserted}`, "Done", 8);
}
function syncHEventLocalizationTexts() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ensureSheet_(ss, "localization_texts");
  const headers = ["key","en","zh_TW","zh_CN","ja","ko","fr","de","it","ru","es_ES","pt_BR","source","notes"];
  ensureHeaders_(sheet, headers);
  const rows = [];
  addL10nRow_(rows, "avg.speaker.driver", "\u591c\u73ed\u53f8\u6a5f", "h_event_lines", "AVG speaker");
  sheetObjects_(ss, "h_event_defs").forEach(x => { if (clean_(x.display_name_key) && clean_(x.display_name)) addL10nRow_(rows, x.display_name_key, x.display_name, "h_event_defs", "H event display name"); });
  sheetObjects_(ss, "h_event_lines").forEach(x => { if (clean_(x.speaker_key) && clean_(x.speaker)) addL10nRow_(rows, x.speaker_key, x.speaker, "h_event_lines", "H event speaker"); });
  sheetObjects_(ss, "h_event_lines").forEach(x => { if (clean_(x.text_key) && clean_(x.text)) addL10nRow_(rows, x.text_key, x.text, "h_event_lines", "H event line"); });
  const result = upsertRows_(sheet, headers, uniqueRows_(rows), row => clean_(row[0]));
  formatSheet_(sheet, headers);
  return result;
}
function addL10nRow_(rows, key, text, source, notes) { rows.push([clean_(key), clean_(text), clean_(text), "", "", "", "", "", "", "", "", "", source || "", notes || ""]); }
