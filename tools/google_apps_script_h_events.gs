function sheetObjects_(ss, name) { const sheet=ss.getSheetByName(name); if(!sheet)return[]; const values=sheet.getDataRange().getValues(); if(values.length<2)return[]; const h=values[0].map(clean_); return values.slice(1).map(r => { const o={}; h.forEach((k,i)=>{ if(k)o[k]=r[i]; }); return o; }).filter(o => Object.values(o).some(v=>clean_(v)!=="")); }
function headerMap_(sheet) { const out={}; sheet.getRange(1,1,1,sheet.getLastColumn()).getValues()[0].forEach((v,i)=>{ const h=clean_(v); if(h) out[h]=i+1; }); return out; }
