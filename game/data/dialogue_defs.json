{
	"break_interaction": [
		{
			"dialogue_id": "break_001",
			"text_key": "dialogue.break_001",
			"text": "Good ride. Let your eyes leave the meter for a moment.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 3,
			"is_active": true
		},
		{
			"dialogue_id": "break_002",
			"text_key": "dialogue.break_002",
			"text": "Breathe slowly. My cab already carried you farther tonight.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 3,
			"is_active": true
		},
		{
			"dialogue_id": "break_003",
			"text_key": "dialogue.break_003",
			"text": "Stretch your shoulders before the next fare. I will keep the engine purring.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_004",
			"text_key": "dialogue.break_004",
			"text": "Need water passenger? The meter is paused right now.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_005",
			"text_key": "dialogue.break_005",
			"text": "Relax your jaw and let your hands leave the wheel for a breath.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_006",
			"text_key": "dialogue.break_006",
			"text": "Blink a few times. Night roads look better with rested eyes.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_007",
			"text_key": "dialogue.break_007",
			"text": "You stayed in the seat for this whole ride. I like that.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_008",
			"text_key": "dialogue.break_008",
			"text": "Let the cab idle in the dark a little longer.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_009",
			"text_key": "dialogue.break_009",
			"text": "A short stop makes the next pickup smoother.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_010",
			"text_key": "dialogue.break_010",
			"text": "Stand up if you can. Even night drivers need to reset their backs.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_011",
			"text_key": "dialogue.break_011",
			"text": "Daylight is still on the windshield. Take it in passenger.",
			"bond_requirement": 0,
			"context_requirement": {"time": "day"},
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_012",
			"text_key": "dialogue.break_012",
			"text": "Sunset makes every route softer. We can slow down with it.",
			"bond_requirement": 0,
			"context_requirement": {"time": "sunfall"},
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_013",
			"text_key": "dialogue.break_013",
			"text": "Late route tonight. Keep this stop gentle.",
			"bond_requirement": 0,
			"context_requirement": {"time": "night"},
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_014",
			"text_key": "dialogue.break_014",
			"text": "Rain on the glass makes a fine little rest stop.",
			"bond_requirement": 0,
			"context_requirement": {"weather": "rain"},
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_015",
			"text_key": "dialogue.break_015",
			"text": "That was a steady fare. This driver noticed.",
			"bond_requirement": 2,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_016",
			"text_key": "dialogue.break_016",
			"text": "You are learning how to get back in the cab faster.",
			"bond_requirement": 2,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_017",
			"text_key": "dialogue.break_017",
			"text": "Rest your eyes. I will watch the road and the shadows.",
			"bond_requirement": 3,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_018",
			"text_key": "dialogue.break_018",
			"text": "No need to rush back. The next passenger can wait one more minute.",
			"bond_requirement": 3,
			"context_requirement": "any",
			"cooldown_minutes": 0,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "break_019",
			"text_key": "dialogue.break_019",
			"text": "Rough ride still counts. You got in and stayed with me.",
			"bond_requirement": 0,
			"context_requirement": {"mood": "troubled"},
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "break_020",
			"text_key": "dialogue.break_020",
			"text": "That route felt good. Let the afterglow settle before the next pickup.",
			"bond_requirement": 0,
			"context_requirement": {"mood": "good"},
			"cooldown_minutes": 0,
			"weight": 2,
			"is_active": true
		}
	],
