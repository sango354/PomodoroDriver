			"text": "The meter is running. Stay with the road in front of us.",
			"bond_requirement": 0,
			"context_requirement": "any",
			"cooldown_minutes": 8,
			"weight": 2,
			"is_active": true
		},
		{
			"dialogue_id": "ambient_004",
			"text_key": "dialogue.ambient_004",
			"text": "The cab will stay quiet for the next few minutes.",
			"bond_requirement": 0,
			"context_requirement": {"time": "day"},
			"cooldown_minutes": 8,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "ambient_005",
			"text_key": "dialogue.ambient_005",
			"text": "Evening fares can be gentle too.",
			"bond_requirement": 0,
			"context_requirement": {"time": "sunfall"},
			"cooldown_minutes": 8,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "ambient_006",
			"text_key": "dialogue.ambient_006",
			"text": "It is late. Let the night driver set an easy pace.",
			"bond_requirement": 0,
			"context_requirement": {"time": "night"},
			"cooldown_minutes": 8,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "ambient_007",
			"text_key": "dialogue.ambient_007",
			"text": "You are settling into the route nicely.",
			"bond_requirement": 2,
			"context_requirement": "any",
			"cooldown_minutes": 10,
			"weight": 1,
			"is_active": true
		},
		{
			"dialogue_id": "ambient_008",
			"text_key": "dialogue.ambient_008",
			"text": "I will keep the cab steady while you handle the fare.",
			"bond_requirement": 3,
