          "dialogue_id": "hcg_008",
          "unlock_cost_fp": 200,
          "initial_emotion": 30,
          "initial_alert": 10
        }
      ],
      "first_boarding_lines": [
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "麻煩送我到這個地址。今天值勤有點久，我想安靜一下。",
          "text_key": "passenger.passenger_c.first_boarding.01"
        }
      ],
      "repeat_boarding_lines": [
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "又見面了。上次那趟車……我回去後有點睡不著。",
          "text_key": "passenger.passenger_c.repeat_boarding.01"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "妳總是能看出我不想讓人看見的地方。",
          "text_key": "passenger.passenger_c.repeat_boarding.02"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "今天如果我又太緊繃，妳會提醒我嗎？",
          "text_key": "passenger.passenger_c.repeat_boarding.03"
        }
      ],
      "parking_lines": [
        {
          "speaker": "Night Driver",
          "text": "Let us stop here for a moment. It is quiet enough."
        },
        {
          "speaker": "Passenger C",
          "text": "Since we stopped, may I ask you a few questions?"
        }
      ],
      "normal_end_lines": [
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "謝謝。至少這趟路讓我稍微喘過氣了。",
          "text_key": "passenger.passenger_c.normal_end.01"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "妳很會讓人放鬆，但我還需要一點時間。",
          "text_key": "passenger.passenger_c.normal_end.02"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "如果還有下次……我希望自己能更坦率一點。",
          "text_key": "passenger.passenger_c.normal_end.03"
        }
      ],
      "failed_lines": [
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "抱歉，這讓我不舒服。我需要停在這裡。",
          "text_key": "passenger.passenger_c.failed.01"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "我還沒準備好，請不要再推進了。",
          "text_key": "passenger.passenger_c.failed.02"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "妳看穿我，和逼我承認，是兩回事。",
          "text_key": "passenger.passenger_c.failed.03"
        }
      ],
      "success_lines": [
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "原來……不用一直撐著，也不會壞掉。",
          "text_key": "passenger.passenger_c.success.01"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "妳沒有逼我，是我自己想再靠近一點。",
          "text_key": "passenger.passenger_c.success.02"
        },
        {
          "speaker": "中性打扮的警官",
          "speaker_key": "passenger.passenger_c.name",
          "text": "我好像第一次知道，放鬆也可以這麼讓人害怕。",
          "text_key": "passenger.passenger_c.success.03"
        }
      ],
      "display_name_key": "passenger.passenger_c.name",
      "short_label": "乘客C",
      "short_label_key": "passenger.passenger_c.short_label"
    },
    {
      "passenger_id": "passenger_d",
      "display_name": "健碩的男子",
      "personality": "",
      "gallery_sequence": [
