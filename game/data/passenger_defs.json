          "unlock_cost_fp": 150,
          "initial_emotion": 25,
          "initial_alert": 5
        },
        {
          "event_id": "passenger_d_event_03",
          "dialogue_id": "hcg_011",
          "unlock_cost_fp": 200,
          "initial_emotion": 30,
          "initial_alert": 10
        },
        {
          "event_id": "passenger_d_event_04",
          "dialogue_id": "hcg_012",
          "unlock_cost_fp": 250,
          "initial_emotion": 35,
          "initial_alert": 15
        }
      ],
      "first_boarding_lines": [
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "麻煩開穩一點。我太太在家等我，我不想耽誤太久。",
          "text_key": "passenger.passenger_d.first_boarding.01"
        }
      ],
      "repeat_boarding_lines": [
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "又是妳……上次那趟車，我回去後想了很久。",
          "text_key": "passenger.passenger_d.repeat_boarding.01"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "我先說好，今天我只是搭車，其他什麼都不會發生。",
          "text_key": "passenger.passenger_d.repeat_boarding.02"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "妳別用那種眼神看我。我不是那種會輕易動搖的人。",
          "text_key": "passenger.passenger_d.repeat_boarding.03"
        }
      ],
      "parking_lines": [
        {
          "speaker": "Night Driver",
          "text": "Let us stop here for a moment. It is quiet enough."
        },
        {
          "speaker": "Passenger D",
          "text": "Since we stopped, may I ask you a few questions?"
        }
      ],
      "normal_end_lines": [
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "到了就好。雖然有點危險，但我還清醒。",
          "text_key": "passenger.passenger_d.normal_end.01"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "妳很會說話，不過我不會每次都被影響。",
          "text_key": "passenger.passenger_d.normal_end.02"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "下次……算了，最好不要再有下次。",
          "text_key": "passenger.passenger_d.normal_end.03"
        }
      ],
      "failed_lines": [
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "夠了。妳再說下去，就是不尊重我和我的家庭。",
          "text_key": "passenger.passenger_d.failed.01"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "我不該上這台車。停車吧。",
          "text_key": "passenger.passenger_d.failed.02"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "妳把誘惑當遊戲，但我不是可以隨便測試的人。",
          "text_key": "passenger.passenger_d.failed.03"
        }
      ],
      "success_lines": [
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "我明明一直提醒自己不能越線……為什麼還是輸了？",
          "text_key": "passenger.passenger_d.success.01"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "妳不是靠力氣贏的，是讓我自己先動搖了。",
          "text_key": "passenger.passenger_d.success.02"
        },
        {
          "speaker": "健碩的男子",
          "speaker_key": "passenger.passenger_d.name",
          "text": "別再問我忠不忠誠了……我現在回答不出來。",
          "text_key": "passenger.passenger_d.success.03"
        }
      ],
      "display_name_key": "passenger.passenger_d.name",
      "short_label": "乘客D",
      "short_label_key": "passenger.passenger_d.short_label"
    }
  ]
