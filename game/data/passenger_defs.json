          "unlock_cost_fp": 150,
          "initial_emotion": 25,
          "initial_alert": 5
        },
        {
          "event_id": "passenger_a_event_03",
          "dialogue_id": "hcg_003",
          "unlock_cost_fp": 200,
          "initial_emotion": 30,
          "initial_alert": 10
        }
      ],
      "first_boarding_lines": [
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "不好意思，我還在跟公司通話……請、請直接開到目的地就好。",
          "text_key": "passenger.passenger_a.first_boarding.01"
        }
      ],
      "repeat_boarding_lines": [
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "又是妳啊……拜託，今天讓我安靜一點到家就好。",
          "text_key": "passenger.passenger_a.repeat_boarding.01"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "我現在真的不能分心，電話那邊還沒結束。",
          "text_key": "passenger.passenger_a.repeat_boarding.02"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "看到妳開車，我反而有點不安了……上次那種感覺還沒忘掉。",
          "text_key": "passenger.passenger_a.repeat_boarding.03"
        }
      ],
      "parking_lines": [
        {
          "speaker": "Night Driver",
          "text": "Let us stop here for a moment. It is quiet enough."
        },
        {
          "speaker": "Passenger A",
          "text": "Since we stopped, may I ask you a few questions?"
        }
      ],
      "normal_end_lines": [
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "總算到了……今天這趟車，比我想像中還累。",
          "text_key": "passenger.passenger_a.normal_end.01"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "謝謝。雖然有點分心，但至少沒有出事。",
          "text_key": "passenger.passenger_a.normal_end.02"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "下次如果又是妳……我會考慮先掛電話再上車。",
          "text_key": "passenger.passenger_a.normal_end.03"
        }
      ],
      "failed_lines": [
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "夠了，我真的還在工作，不要再繼續了。",
          "text_key": "passenger.passenger_a.failed.01"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "妳這樣太危險了，我沒辦法再坐下去。",
          "text_key": "passenger.passenger_a.failed.02"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "停車。我現在需要下車冷靜一下。",
          "text_key": "passenger.passenger_a.failed.03"
        }
      ],
      "success_lines": [
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "不行……我剛剛差點在電話裡露出破綻。",
          "text_key": "passenger.passenger_a.success.01"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "妳到底是怎麼做到的……我明明一直在忍。",
          "text_key": "passenger.passenger_a.success.02"
        },
        {
          "speaker": "溫吞的年輕人",
          "speaker_key": "passenger.passenger_a.name",
          "text": "拜託，先別讓我下車……我現在還沒辦法像平常一樣說話。",
          "text_key": "passenger.passenger_a.success.03"
        }
      ],
      "display_name_key": "passenger.passenger_a.name",
      "short_label": "乘客A",
      "short_label_key": "passenger.passenger_a.short_label"
    },
    {
      "passenger_id": "passenger_b",
      "display_name": "看起來霸氣的人",
      "personality": "",
      "gallery_sequence": [
        {
          "event_id": "passenger_b_event_01",
          "dialogue_id": "hcg_004",
          "unlock_cost_fp": 100,
          "initial_emotion": 20,
          "initial_alert": 0
        },
        {
          "event_id": "passenger_b_event_02",
          "dialogue_id": "hcg_005",
          "unlock_cost_fp": 150,
          "initial_emotion": 25,
          "initial_alert": 5
        }
      ],
      "first_boarding_lines": [
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "開車。路線我會看著，別試圖用那些廉價話術取悅我。",
          "text_key": "passenger.passenger_b.first_boarding.01"
        }
      ],
      "repeat_boarding_lines": [
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "又是妳？看來今晚的路程不會太無聊。",
          "text_key": "passenger.passenger_b.repeat_boarding.01"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "上次妳以為自己掌控了局面，結果如何，還記得嗎？",
          "text_key": "passenger.passenger_b.repeat_boarding.02"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "我今天心情不錯。妳可以試著再挑釁我一次。",
          "text_key": "passenger.passenger_b.repeat_boarding.03"
        }
      ],
      "parking_lines": [
        {
          "speaker": "Night Driver",
          "text": "Let us stop here for a moment. It is quiet enough."
        },
        {
          "speaker": "Passenger B",
          "text": "Since we stopped, may I ask you a few questions?"
        }
      ],
      "normal_end_lines": [
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "今晚算妳沒失分，但也沒有讓我盡興。",
          "text_key": "passenger.passenger_b.normal_end.01"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "妳的眼神有趣，可惜膽子還不夠。",
          "text_key": "passenger.passenger_b.normal_end.02"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "下次再見時，希望妳準備好被反咬一口。",
          "text_key": "passenger.passenger_b.normal_end.03"
        }
      ],
      "failed_lines": [
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "無趣。妳的挑釁只有表面，沒有牙齒。",
          "text_key": "passenger.passenger_b.failed.01"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "我不喜歡被浪費時間。停車。",
          "text_key": "passenger.passenger_b.failed.02"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "妳還沒資格碰我的本性。",
          "text_key": "passenger.passenger_b.failed.03"
        }
      ],
      "success_lines": [
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "很好，妳終於把真正的我引出來了。",
          "text_key": "passenger.passenger_b.success.01"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "獵人和獵物的位置，現在該重新分配了。",
          "text_key": "passenger.passenger_b.success.02"
        },
        {
          "speaker": "看起來霸氣的人",
          "speaker_key": "passenger.passenger_b.name",
          "text": "別急著求饒。這不是妳想要的結果嗎？",
          "text_key": "passenger.passenger_b.success.03"
        }
      ],
      "display_name_key": "passenger.passenger_b.name",
      "short_label": "乘客B",
      "short_label_key": "passenger.passenger_b.short_label"
    },
    {
      "passenger_id": "passenger_c",
      "display_name": "中性打扮的警官",
      "personality": "",
      "gallery_sequence": [
        {
          "event_id": "passenger_c_event_01",
          "dialogue_id": "hcg_006",
          "unlock_cost_fp": 100,
